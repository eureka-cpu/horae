  "query": "SELECT id, name, email, active, org_role::text AS \"org_role!: String\",\n         cost_rate_cents, billable_rate_cents,\n         created_at as \"created_at: chrono::DateTime<chrono::Utc>\"\n         FROM users\n         WHERE org_id = $1\n           AND ($2::bool IS NULL OR active = $2)\n         ORDER BY name\n         LIMIT $3 OFFSET $4",

  "query": "SELECT t.id, t.org_id, t.name, t.billable_default, t.default_rate_cents, t.active\n         FROM tasks t\n         JOIN project_tasks pt ON t.id = pt.task_id\n         WHERE pt.project_id = $1 AND t.active = true\n         ORDER BY t.name",
